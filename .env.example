# ═══════════════════════════════════════════════════════
#  ASSENT v2.0 — Variáveis de Ambiente
#  
#  INSTRUÇÕES:
#  1. Copie este arquivo: cp .env.example .env
#  2. Preencha os valores com as suas credenciais do Firebase
#  3. NUNCA commite o arquivo .env — ele está no .gitignore
#
#  As credenciais estão no Firebase Console:
#  https://console.firebase.google.com → Configurações do Projeto → Seus apps
# ═══════════════════════════════════════════════════════

# Firebase — Autenticação e Banco de Dados
VITE_FIREBASE_API_KEY=sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu_projeto_id
VITE_FIREBASE_STORAGE_BUCKET=seu_projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id
VITE_FIREBASE_APP_ID=seu_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_RECAPTCHA_SITE_KEY=sua_chave_aqui
